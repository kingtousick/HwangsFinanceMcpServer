# 선택적 폴백 소스용 API 키. 없으면 해당 소스는 건너뛴다.
# 한국수출입은행 환율 API (가정용 PC 환율 폴백). https://www.koreaexim.go.kr 에서 발급.
EXIM_API_KEY=
# Finnhub (미국 주식 폴백, 현재 미사용/예약).
FINNHUB_KEY=
# 국토교통부 실거래가 API (data.go.kr 활용신청 후 발급되는 'Decoding(일반)' 키).
# get_apt_trade / get_apt_rent 에 필요. Encoding 키를 넣으면 이중 인코딩으로 깨짐.
MOLIT_API_KEY=

# --- 공사현황(철도/광역교통) 도구 ---------------------------------------------
# data.go.kr Decoding(일반) 키. 계정 단위라 MOLIT_API_KEY와 동일 키를 쓰면 된다
# (미설정 시 MOLIT_API_KEY로 폴백). 단, 각 서비스를 data.go.kr에서 별도 활용신청해야 함:
#   - 나라장터 입찰공고정보서비스   → get_construction_bids
#   - (관보고시는 파일데이터이며 아래 URL 환경변수 사용)
DATA_GO_KR_API_KEY=

# 열린재정(openfiscaldata.go.kr) OpenAPI 인증키. get_project_budget 에 필요.
OPEN_FISCAL_API_KEY=
# 열린재정 재정사업 예산 API명/검색 파라미터명(인증 후 OPEN API 탭에서 확인해 실제 값으로 교체).
# 기본 추정값이 안 맞으면 아래를 설정한다(sources/fiscal.py 참고).
OPEN_FISCAL_API_NAME=
OPEN_FISCAL_KW_PARAM=

# 국가철도공단 관보고시 파일데이터(JSON) 다운로드 URL. get_rail_notices 에 필요.
# data.go.kr 데이터셋 페이지에서 JSON 다운로드 URL을 확인해 설정(sources/kr_notice.py 참고).
KRNA_NOTICE_URL_BASIC=
KRNA_NOTICE_URL_PLAN=
KRNA_NOTICE_URL_DETAIL=
