# 선택적 폴백 소스용 API 키. 없으면 해당 소스는 건너뛴다.
# 한국수출입은행 환율 API (가정용 PC 환율 폴백). https://www.koreaexim.go.kr 에서 발급.
EXIM_API_KEY=
# Finnhub (미국 주식 폴백, 현재 미사용/예약).
FINNHUB_KEY=
# 국토교통부 실거래가 API (data.go.kr 활용신청 후 발급되는 'Decoding(일반)' 키).
# get_apt_trade / get_apt_rent 에 필요. Encoding 키를 넣으면 이중 인코딩으로 깨짐.
MOLIT_API_KEY=

# --- 공사현황(철도/광역교통) 도구 ---------------------------------------------
# data.go.kr Decoding(일반) 키. 계정 단위라 MOLIT_API_KEY와 동일 키를 쓰면 된다
# (미설정 시 MOLIT_API_KEY로 폴백). 단, 각 서비스를 data.go.kr에서 별도 활용신청해야 함:
#   - 나라장터 입찰공고정보서비스   → get_construction_bids
#   - (관보고시는 파일데이터이며 아래 URL 환경변수 사용)
DATA_GO_KR_API_KEY=

# 열린재정(openfiscaldata.go.kr) OpenAPI 인증키. get_project_budget 에 필요.
OPEN_FISCAL_API_KEY=
# 열린재정은 API명을 SERVICE 쿼리 파라미터로 받는다(코드가 base?SERVICE=<이름> 형식으로 호출).
# 아래 SERVICE명/검색 파라미터명은 로그인 후 데이터셋 'OPEN API 탭'의 '요청인자'에서 확인해
# 실제 값으로 넣어야 한다(안 맞으면 RESULT.CODE=ERROR-310 → fallback). sources/fiscal.py 참고.
#   OPEN_FISCAL_API_NAME : 재정사업 예산 시계열 SERVICE명(실제 값 필수 — 기본 추정값은 404/310)
#   OPEN_FISCAL_KW_PARAM : 사업명 검색 파라미터명(예: OFFC_NM 등 실제 요청인자명)
OPEN_FISCAL_API_NAME=
OPEN_FISCAL_KW_PARAM=

# 국가철도공단 관보고시 오픈API 엔드포인트 URL. get_rail_notices 에 필요.
# ※ 여기는 '인증키'가 아니라 URL 자리다. data.go.kr 파일데이터(15114027 등)는 odcloud.kr
#   오픈API로 자동변환되며, 데이터셋의 'OpenAPI/미리보기' 탭에 아래 형태의 URL이 있다:
#     https://api.odcloud.kr/api/15114027/v1/uddi:xxxxxxxx-....
#   serviceKey는 코드가 DATA_GO_KR_API_KEY(=MOLIT_API_KEY)로 자동 첨부하므로 URL만 넣는다.
KRNA_NOTICE_URL_BASIC=
KRNA_NOTICE_URL_PLAN=
KRNA_NOTICE_URL_DETAIL=
